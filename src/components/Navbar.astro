---
const navLinks = [
  { label: "Blog", href: "/blog" },
  { label: "About", href: "/about" },
  { label: "Recommendations", href: "/recommendations" },
  { label: "Pricing", href: "/pricing" },
];

const currentPath = Astro.url.pathname;
---

<header class="navbar">
  <div class="navbar-inner">
    <a href="/" class="logo">Tony Medel</a>

    <nav class="nav-links">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`nav-link ${currentPath === link.href ? "active" : ""}`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: #111;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    font-family: "DM Sans", sans-serif;
  }

  .navbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .logo:hover {
    color: #e2e2e2;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 450;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.15s ease;
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: #fff;
    transition: width 0.2s ease;
  }

  .nav-link:hover {
    color: #fff;
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-link.active {
    color: #fff;
  }

  @media (max-width: 640px) {
    .navbar-inner {
      padding: 0 1.25rem;
    }

    .nav-links {
      gap: 1.25rem;
    }

    .nav-link {
      font-size: 0.875rem;
    }
  }
</style>